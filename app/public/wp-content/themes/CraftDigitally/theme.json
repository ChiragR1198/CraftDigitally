{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1440px"
		},
		"color": {
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"defaultGradients": true,
			"defaultPalette": true,
			"link": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#4a2c7d",
					"name": "Primary"
				},
				{
					"slug": "text",
					"color": "#363636",
					"name": "Text"
				},
				{
					"slug": "background-light",
					"color": "#f2efed",
					"name": "Background Light"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textDecoration": true,
			"textTransform": true,
			"dropCap": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Newsreader\", Georgia, serif",
					"slug": "heading",
					"name": "Heading Font"
				},
				{
					"fontFamily": "\"Mona Sans\", Helvetica, sans-serif",
					"slug": "body",
					"name": "Body Font"
				},
				{
					"fontFamily": "\"Public Sans\", Helvetica, sans-serif",
					"slug": "public-sans",
					"name": "Public Sans"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "14px",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "16px",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "18px",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "24px",
					"name": "Extra Large"
				},
				{
					"slug": "heading-2",
					"size": "40px",
					"name": "Heading 2"
				},
				{
					"slug": "heading-1",
					"size": "56px",
					"name": "Heading 1"
				}
			]
		},
		"spacing": {
			"customSpacingSize": true,
			"spacingSizes": [
				{
					"slug": "small",
					"size": "16px",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "24px",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "32px",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "64px",
					"name": "Extra Large"
				}
			],
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"custom": {
			"spacing": {
				"small": "16px",
				"medium": "24px",
				"large": "32px",
				"xlarge": "64px",
				"xxlarge": "128px"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background-light)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--large)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"top": "0px",
				"right": "0px",
				"bottom": "0px",
				"left": "0px"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--text)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--heading-1)",
					"fontWeight": "400",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--heading-2)",
					"fontWeight": "500",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "2px"
				},
				":hover": {
					"color": {
						"background": "#3a1c6d"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "2px"
				}
			},
			"core/group": {
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--large)",
						"bottom": "var(--wp--custom--spacing--large)"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}